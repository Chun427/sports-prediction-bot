"""V3.1 additive：台灣運彩「模型方向」行（V1-style MC argmax）。
驗證：argmax 正確、NBA 無假和局、env 可關、不動 best_pick/Kelly。"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))
import notifier as nf

FIFA = {"sport": "FIFA", "home": "Brazil", "away": "Morocco",
        "model_mc": {"win_prob": {"home": 0.459, "draw": 0.263, "away": 0.278}}}
NBA = {"sport": "NBA", "home": "Lakers", "away": "Celtics",
       "model_mc": {"win_prob": {"home": 0.62, "away": 0.38}}}


def test_direction_argmax_fifa(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(FIFA)
    assert "🧭【模型方向】Brazil 主勝（MC 45.9%）" in out
    assert "非 +EV 投注建議" in out  # 誠實標註存在


def test_direction_nba_no_fake_draw(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(NBA)
    assert "🧭【模型方向】Lakers 主勝（MC 62.0%）" in out
    assert "和局" not in out.split("🧭【模型方向】")[1].splitlines()[0]  # 方向行不得出現和局


def test_direction_switch_off(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "false")
    out = nf.render_pregame_lite(FIFA)
    assert "🧭【模型方向】N/A" in out


def test_best_pick_and_kelly_untouched(monkeypatch):
    # 無 best_pick → 主推仍 N/A；模型方向不影響主推/Kelly
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(FIFA)
    assert "🔮【主推】N/A" in out          # best_pick 為空 → 主推 N/A（誠實，未被方向覆蓋）
    assert "📊 風控資訊" in out and "Kelly：" in out
