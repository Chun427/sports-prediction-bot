"""V3.2 顯示層：早/最終標題、次要/備選填線值。純顯示，不動預測邏輯。"""
import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))
import notifier as nf

FIFA = {"sport": "FIFA", "home": "Belgium", "away": "Egypt",
        "start_time": "2026-06-16T03:00:00+08:00",
        "model_mc": {"win_prob": {"home": 0.615, "draw": 0.231, "away": 0.154}},
        "model_score": {"type": "poisson", "expected_total": 2.5, "supremacy": 0.5,
                        "top_scorelines": [{"home": 1, "away": 0, "prob": 0.12}]},
        "fair_prob": {}, "best_odds": {}, "edge": {}}
NBA = {"sport": "NBA", "home": "Lakers", "away": "Celtics",
       "model_mc": {"win_prob": {"home": 0.62, "away": 0.38}},
       "fair_prob": {}, "best_odds": {}, "edge": {}}   # 無 model_score → 無總分/讓分


def test_final_header_has_lightning_no_clock(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(FIFA)
    assert "⚡ 量化預測模型（賽前 40 分鐘）" in out
    assert "🕐" not in out


def test_early_header_has_clock_no_lightning(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_early(FIFA)
    assert "🕐 量化預測模型（賽前 12小時預測）" in out
    assert "⚡" not in out
    # 內文與最終同資料來源（主推方向仍在）
    assert "🔮【主推】獨贏盤 → Belgium 勝出" in out


def test_secondary_and_backup_filled_when_data(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(FIFA)
    assert "💎【次要】總分大小 → 盤口 2.5" in out
    assert "⭐【備選】讓分盤 → Belgium -0.5" in out


def test_secondary_backup_na_when_no_score(monkeypatch):
    monkeypatch.setenv("USE_V1_DECISION", "true")
    out = nf.render_pregame_lite(NBA)        # 無 model_score
    assert "💎【次要】N/A" in out
    assert "⭐【備選】N/A" in out
    # 主推仍有方向（MC argmax）
    assert "🔮【主推】獨贏盤 → Lakers 勝出" in out
